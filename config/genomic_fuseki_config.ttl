@prefix :        <http://jena.apache.org/fuseki#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb:     <http://jena.hpl.hp.com/2008/tdb#> .
@prefix tdb2:    <http://jena.apache.org/2016/tdb#> .
@prefix ja:      <http://jena.hpl.hp.com/2005/11/Assembler#> .

:service_ds rdf:type :Service ;
    :name "/ds" ;
    :serviceQuery "query" , "sparql" ;
    :serviceUpdate "update" ;
    :serviceUpload "upload" ;
    :dataset :tdb2_dataset .

:tdb2_dataset rdf:type tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki/databases/ds" ;
    tdb2:unionDefaultGraph false ;
    .
