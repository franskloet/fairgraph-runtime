# LLM Configuration (Default is local Ollama)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:1.5b
LLM_SEARCH_ENABLED=false

# Ollama Endpoint Configuration
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# Alternative API Keys (Leave blank to use Ollama)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Image Configurations for Dynamic database/API provisioning
FUSEKI_IMAGE=frnzdock/fairgraph-fuseki:latest
API_IMAGE=frnzdock/fairgraph-api:latest
